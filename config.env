# Development Configuration
# Build Order and Configuration
# Format: BUILD_NAME:BUILD_TYPE (bitbake or refui)
# Comma-separated list of builds to execute in order
BUILD_LIST="base:bitbake,wpe:bitbake,refui:refui"

# Base (meta-bolt-distro) Configuration
BASE_REPO_URL=https://github.com/rdkcentral/meta-bolt-distro
BASE_VERSION=0.2.0
BASE_BOLT_MAKE_TARGET=base

# WPE (meta-bolt-wpe) Configuration
WPE_REPO_URL=https://github.com/rdkcentral/meta-bolt-wpe
WPE_VERSION=0.2.0
WPE_BOLT_MAKE_TARGET=wpe

# RefUI (rdke-refui) Configuration
REFUI_REPO_URL=https://github.com/rdkcentral/rdke-refui
REFUI_VERSION=6.0.3

# Bolt env content
# BOLT_REPO_SYNC_PARAMS: Parameters for repo sync command
#   --no-clone-bundle: Don't use bundle clones (faster on some networks)
#   -j$(getconf _NPROCESSORS_ONLN): Parallel jobs based on CPU count
BOLT_REPO_SYNC_PARAMS="--no-clone-bundle  -j$(getconf _NPROCESSORS_ONLN)"

# BOLT_DL_DIR: Directory for downloaded build artifacts (saves bandwidth on rebuilds)
BOLT_DL_DIR=${HOME}/downloads

# BOLT_SSTATE_DIR: Shared state cache directory (significantly speeds up builds)
BOLT_SSTATE_DIR=${HOME}/sstate-cache

# Test signing keys
PRIVATE_KEY_PATH=./keys/private.key
PUBLIC_KEY_PATH=./keys/public.key
PRIVATE_KEY_PASSPHRASE=
KEY_FORMAT=PEM

# Local directories
WORK_DIR=./work
BOLTS_DIR=./bolts

# Manifest
MANIFEST_FILE=./bolts/factory-app-version.json

# Ralfpack bin path
RALFPACK_BIN=/usr/bin/ralfpack

